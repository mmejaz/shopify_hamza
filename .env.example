# Copy this file to `.env` and fill in the values.

# Your store's myshopify handle (without .myshopify.com)
SHOPIFY_STORE=onteriorenterprises-com

# The CLI reads this natively as the target store for every command.
SHOPIFY_FLAG_STORE=onteriorenterprises-com

# ── Auth: Theme Access token (recommended for Docker — NO interactive login) ──
# Install the free "Theme Access" app in admin, create a password, paste the
# shptka_... token here. With this set, the container never asks you to log in.
#   admin -> Apps -> "Theme Access" (by Shopify)
SHOPIFY_CLI_THEME_TOKEN=

# Storefront password — ONLY needed while the store is password-protected
# ("Opening soon"). Find/set it in: Online Store -> Preferences -> Password protection
# Leave empty once the store is public.
SHOPIFY_STORE_PASSWORD=
