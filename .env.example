# Copy this file to `.env` and fill in the values.

# Your store's myshopify handle (without .myshopify.com)
SHOPIFY_STORE=onteriorenterprises-com

# Storefront password — ONLY needed while the store is password-protected
# ("Opening soon"). Find/set it in Shopify admin:
#   Online Store -> Preferences -> Password protection
# Leave empty once the store is public.
SHOPIFY_STORE_PASSWORD=
