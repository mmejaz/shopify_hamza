{%- comment -%}
  Onterior — Home CTA ("Designed to Inspire"). Full-bleed dark image banner.
{%- endcomment -%}

{{ 'onterior-base.css' | asset_url | stylesheet_tag }}

<section class="ont onterior-cta">
  {%- if section.settings.image != blank -%}
    {%- assign cta_alt = section.settings.image.alt | default: '' -%}
    {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy', sizes: '100vw', widths: '800, 1200, 1600, 2000', alt: cta_alt, class: 'ont-cta__img' }}
  {%- elsif section.settings.image_asset != blank -%}
    <img class="ont-cta__img" src="{{ section.settings.image_asset | asset_url }}" alt="{{ section.settings.image_alt | escape }}" loading="lazy" width="2000" height="1000">
  {%- else -%}
    {{ 'lifestyle-2' | placeholder_svg_tag: 'ont-cta__img ont-cta__ph' }}
  {%- endif -%}
  <span class="ont-cta__scrim" aria-hidden="true"></span>

  <div class="ont-container ont-cta__inner">
    {%- if section.settings.eyebrow != blank -%}<p class="ont-eyebrow ont-reveal" style="color: var(--ont-sand);">{{ section.settings.eyebrow }}</p>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="ont-serif ont-cta__title ont-reveal">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.body != blank -%}<p class="ont-cta__body ont-reveal">{{ section.settings.body }}</p>{%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a class="ont-cta__btn ont-reveal" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

<script src="{{ 'onterior.js' | asset_url }}" defer="defer"></script>

{% stylesheet %}
  .onterior-cta { position: relative; min-height: 380px; overflow: hidden; background: var(--ont-ink); display: flex; }
  .ont-cta__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .ont-cta__ph { background: var(--ont-coal); }
  .ont-cta__scrim { position: absolute; inset: 0; background: linear-gradient(to right, rgba(22,19,17,.9), rgba(22,19,17,.5) 55%, rgba(22,19,17,.1)); }
  .ont-cta__inner { position: relative; z-index: 2; width: 100%; padding-top: 64px; padding-bottom: 64px; display: flex; flex-direction: column; justify-content: center; }
  .ont-cta__title { color: var(--ont-cream); font-weight: 500; font-size: 36px; line-height: 1.12; max-width: 420px; margin: 0; }
  @media (min-width: 1024px) { .ont-cta__title { font-size: 46px; } }
  .ont-cta__body { margin-top: 20px; max-width: 300px; color: rgba(247,243,236,.75); font-size: 14px; line-height: 1.65; font-weight: 300; }
  .ont-cta__btn { margin-top: 32px; align-self: flex-start; border: 1px solid rgba(247,243,236,.7); color: var(--ont-cream); font-size: 11px; letter-spacing: .16em; text-transform: uppercase; font-weight: 500; padding: 14px 32px; text-decoration: none; transition: background-color .3s, color .3s; }
  .ont-cta__btn:hover { background: var(--ont-cream); color: var(--ont-ink); }
{% endstylesheet %}

{% schema %}
{
  "name": "Home CTA",
  "tag": "section",
  "class": "section-onterior-cta",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image (upload)" },
    { "type": "text", "id": "image_asset", "label": "Background asset filename", "info": "Fallback: a file in assets/, e.g. onterior-lower-banner.png." },
    { "type": "text", "id": "image_alt", "label": "Background alt text" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Inspired Living" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Designed to Inspire" },
    { "type": "text", "id": "body", "label": "Body", "default": "Each piece is thoughtfully designed to blend beauty with purpose." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "View Lookbook" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Home CTA" }]
}
{% endschema %}
