{%- comment -%}
  Onterior — Contact. Intro + contact details on the left, an elegant Shopify
  contact form on the right. Styled to the Onterior brand scheme.
{%- endcomment -%}

{{ 'onterior-base.css' | asset_url | stylesheet_tag }}

<section class="ont onterior-contact" style="background: var(--ont-cream);">
  <div class="ont-container ont-ct__grid">

    {%- comment -%} Left: intro + details {%- endcomment -%}
    <div class="ont-ct__intro ont-reveal">
      {%- if section.settings.eyebrow != blank -%}<p class="ont-eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h1 class="ont-serif ont-ct__title">{{ section.settings.heading }}</h1>{%- endif -%}
      {%- if section.settings.body != blank -%}<div class="ont-ct__body rte">{{ section.settings.body }}</div>{%- endif -%}

      <ul class="ont-ct__details">
        {%- if section.settings.phone != blank -%}
          <li>
            <span class="ont-ct__dicon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M4 5c0 8.3 6.7 15 15 15 .6 0 1-.4 1-1v-3.2c0-.5-.3-.9-.8-1l-3-.7c-.4-.1-.9.1-1.1.5l-1 1.6a12.3 12.3 0 0 1-5.6-5.6l1.6-1c.4-.2.6-.7.5-1.1l-.7-3c-.1-.5-.5-.8-1-.8H5c-.6 0-1 .4-1 1z"/></svg></span>
            <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}">{{ section.settings.phone }}</a>
          </li>
        {%- endif -%}
        {%- if section.settings.email != blank -%}
          <li>
            <span class="ont-ct__dicon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M4 7l8 6 8-6"/></svg></span>
            <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
          </li>
        {%- endif -%}
        {%- if section.settings.address != blank -%}
          <li>
            <span class="ont-ct__dicon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 21s7-5.6 7-11a7 7 0 1 0-14 0c0 5.4 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/></svg></span>
            <span>{{ section.settings.address }}</span>
          </li>
        {%- endif -%}
      </ul>
    </div>

    {%- comment -%} Right: form {%- endcomment -%}
    <div class="ont-ct__formwrap ont-reveal ont-d1">
      {%- form 'contact', class: 'ont-ct__form' -%}
        {%- if form.posted_successfully? -%}
          <p class="ont-ct__success">{{ section.settings.success_text | default: "Thank you — your message has been sent. We'll be in touch soon." }}</p>
        {%- endif -%}
        {%- if form.errors -%}
          <div class="ont-ct__errors">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <div class="ont-ct__row">
          <div class="ont-ct__field">
            <label for="ct-name">Name</label>
            <input id="ct-name" type="text" name="contact[name]" value="{{ form.name }}" autocomplete="name" placeholder="Your name">
          </div>
          <div class="ont-ct__field">
            <label for="ct-email">Email <span aria-hidden="true">*</span></label>
            <input id="ct-email" type="email" name="contact[email]" value="{{ form.email }}" required autocomplete="email" placeholder="you@email.com">
          </div>
        </div>

        <div class="ont-ct__field">
          <label for="ct-phone">Phone</label>
          <input id="ct-phone" type="tel" name="contact[phone]" value="{{ form.phone }}" autocomplete="tel" placeholder="Optional">
        </div>

        <div class="ont-ct__field">
          <label for="ct-body">Message <span aria-hidden="true">*</span></label>
          <textarea id="ct-body" name="contact[body]" rows="5" required placeholder="How can we help?">{{ form.body }}</textarea>
        </div>

        <button type="submit" class="ont-ct__submit">
          {{ section.settings.button_label | default: 'Send Message' }}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6l6 6-6 6"/></svg>
        </button>
      {%- endform -%}
    </div>

  </div>
</section>

<script src="{{ 'onterior.js' | asset_url }}" defer="defer"></script>

{% stylesheet %}
  .onterior-contact { padding-top: 64px; padding-bottom: 72px; }
  @media (min-width: 1024px) { .onterior-contact { padding-top: 96px; padding-bottom: 104px; } }
  .ont-ct__grid { display: grid; grid-template-columns: 1fr; gap: 48px; align-items: start; }
  @media (min-width: 1024px) { .ont-ct__grid { grid-template-columns: 5fr 7fr; gap: 72px; } }

  .ont-ct__title { font-size: 34px; line-height: 1.15; margin: 0; color: var(--ont-ink); font-weight: 600; }
  @media (min-width: 1024px) { .ont-ct__title { font-size: 44px; } }
  .ont-ct__title em { color: var(--ont-gold); font-style: italic; font-weight: 500; }
  .ont-ct__body { margin-top: 22px; max-width: 26rem; font-size: 14.5px; line-height: 1.9; font-weight: 300; color: var(--ont-stone); }
  .ont-ct__body p { margin: 0 0 1em; }

  .ont-ct__details { list-style: none; margin: 36px 0 0; padding: 0; display: flex; flex-direction: column; gap: 20px; }
  .ont-ct__details li { display: flex; align-items: center; gap: 16px; font-size: 14px; color: var(--ont-ink); }
  .ont-ct__details a { color: var(--ont-ink); text-decoration: none; transition: color .3s; }
  .ont-ct__details a:hover { color: var(--ont-gold); }
  .ont-ct__dicon { flex: 0 0 auto; display: grid; place-items: center; width: 44px; height: 44px; border-radius: 999px; border: 1px solid rgba(185,138,68,.5); color: var(--ont-gold); }
  .ont-ct__dicon svg { width: 19px; height: 19px; }

  /* Form */
  .ont-ct__formwrap { background: #fff; border: 1px solid rgba(22,19,17,.08); padding: 32px; box-shadow: 0 30px 60px -30px rgba(22,19,17,.18); }
  @media (min-width: 640px) { .ont-ct__formwrap { padding: 44px; } }
  .ont-ct__row { display: grid; grid-template-columns: 1fr; gap: 22px; }
  @media (min-width: 640px) { .ont-ct__row { grid-template-columns: 1fr 1fr; } }
  .ont-ct__field { display: flex; flex-direction: column; margin-bottom: 22px; }
  .ont-ct__row .ont-ct__field { margin-bottom: 0; }
  .ont-ct__field label { font-size: 11px; letter-spacing: .14em; text-transform: uppercase; font-weight: 600; color: var(--ont-ink); margin-bottom: 10px; }
  .ont-ct__field label span { color: var(--ont-gold); }
  .ont-ct__field input,
  .ont-ct__field textarea {
    width: 100%; background: var(--ont-cream); border: 1px solid rgba(22,19,17,.14); padding: 14px 16px;
    font-family: var(--ont-sans); font-size: 14px; color: var(--ont-ink); transition: border-color .3s, background-color .3s;
  }
  .ont-ct__field textarea { resize: vertical; min-height: 120px; }
  .ont-ct__field input::placeholder,
  .ont-ct__field textarea::placeholder { color: rgba(110,103,92,.6); }
  .ont-ct__field input:focus,
  .ont-ct__field textarea:focus { outline: none; border-color: var(--ont-gold); background: #fff; }

  .ont-ct__submit {
    margin-top: 28px; display: inline-flex; align-items: center; gap: 12px; background: var(--ont-ink); color: var(--ont-cream);
    border: 0; cursor: pointer; padding: 16px 34px; font-family: var(--ont-sans); font-size: 12px; font-weight: 500;
    letter-spacing: .18em; text-transform: uppercase; transition: background-color .3s ease;
  }
  .ont-ct__submit svg { width: 16px; height: 16px; transition: transform .3s ease; }
  .ont-ct__submit:hover { background: var(--ont-gold); }
  .ont-ct__submit:hover svg { transform: translateX(5px); }

  .ont-ct__success { background: rgba(185,138,68,.12); border: 1px solid rgba(185,138,68,.4); color: var(--ont-ink); padding: 14px 18px; margin: 0 0 24px; font-size: 14px; }
  .ont-ct__errors { color: #a3341f; font-size: 13px; margin: 0 0 22px; }
  .ont-ct__errors ul { margin: 0; padding-left: 18px; }
{% endstylesheet %}

{% schema %}
{
  "name": "Onterior contact",
  "tag": "section",
  "class": "section-onterior-contact",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Get In Touch" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Let's Create Something <em>Timeless.</em>" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Questions, custom orders, or just to say hello — reach out and our team will get back to you shortly.</p>" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "(336) 475-0548" },
    { "type": "text", "id": "email", "label": "Email", "default": "info@onteriorenterprises.com" },
    { "type": "textarea", "id": "address", "label": "Address", "default": "Greensboro, NC, USA" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Send Message" },
    { "type": "text", "id": "success_text", "label": "Success message", "default": "Thank you — your message has been sent. We'll be in touch soon." }
  ],
  "presets": [{ "name": "Onterior contact" }]
}
{% endschema %}
