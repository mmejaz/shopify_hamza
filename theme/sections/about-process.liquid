{%- comment -%}
  Onterior — Process. Intro column + numbered step cards (blocks).
{%- endcomment -%}

{{ 'onterior-base.css' | asset_url | stylesheet_tag }}

<section class="ont onterior-process" style="background: var(--ont-cream);">
  <div class="ont-container">
    <div class="ont-process__grid">

      <div class="ont-process__intro ont-reveal">
        {%- if section.settings.eyebrow != blank -%}<p class="ont-eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="ont-serif ont-process__title">{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.body != blank -%}<div class="ont-process__body rte">{{ section.settings.body }}</div>{%- endif -%}
      </div>

      <div class="ont-process__steps">
        {%- for block in section.blocks -%}
          {%- assign delay = forloop.index0 | modulo: 4 -%}
          <div class="ont-step ont-reveal ont-d{{ delay }}" {{ block.shopify_attributes }}>
            <div class="ont-zoom ont-step__media">
              {%- if block.settings.image != blank -%}
                {%- assign step_alt = block.settings.image.alt | default: block.settings.title -%}
                {{ block.settings.image | image_url: width: 600 | image_tag:
                  loading: 'lazy', sizes: '(min-width: 1024px) 220px, 45vw', widths: '300, 450, 600',
                  alt: step_alt,
                  class: 'ont-step__img' }}
              {%- else -%}
                {{ 'product-apparel-1' | placeholder_svg_tag: 'ont-step__img ont-placeholder' }}
              {%- endif -%}
            </div>
            <div class="ont-step__rule">
              <span class="ont-step__num">{{ block.settings.number }}</span>
            </div>
            {%- if block.settings.title != blank -%}<h3 class="ont-step__title">{{ block.settings.title }}</h3>{%- endif -%}
            {%- if block.settings.text != blank -%}<p class="ont-step__text">{{ block.settings.text }}</p>{%- endif -%}
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

<script src="{{ 'onterior.js' | asset_url }}" defer="defer"></script>

{% stylesheet %}
  .onterior-process { padding-top: 64px; padding-bottom: 64px; }
  @media (min-width: 1024px) { .onterior-process { padding-top: 96px; padding-bottom: 96px; } }
  .ont-process__grid { display: grid; gap: 40px; align-items: start; }
  @media (min-width: 1024px) { .ont-process__grid { grid-template-columns: 4fr 8fr; gap: 32px; } }
  .ont-process__title { font-size: 30px; line-height: 1.2; margin: 0; font-weight: 600; }
  @media (min-width: 640px) { .ont-process__title { font-size: 38px; } }
  .ont-process__body { margin-top: 24px; max-width: 20rem; font-size: 14.5px; line-height: 1.9; color: var(--ont-stone); }
  .ont-process__steps { display: grid; grid-template-columns: repeat(2, 1fr); gap: 40px 24px; }
  @media (min-width: 1280px) { .ont-process__steps { grid-template-columns: repeat(4, 1fr); } }
  .ont-step__media { }
  .ont-step__img { width: 100%; height: 144px; object-fit: cover; }
  .ont-step__rule { position: relative; margin: 24px 0 16px; border-top: 1px solid rgba(22,19,17,.15); }
  .ont-step__num {
    position: absolute; left: 0; top: -14px; background: var(--ont-ink); color: var(--ont-cream);
    font-size: 10px; letter-spacing: 0.15em; padding: 6px 10px;
  }
  .ont-step__title { font-size: 12.5px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.14em; margin: 0; transition: color .3s ease; }
  .ont-step:hover .ont-step__title { color: var(--ont-gold); }
  .ont-step__text { margin-top: 8px; font-size: 13px; line-height: 1.6; color: var(--ont-stone); }
  .ont-placeholder { background: var(--ont-linen); }
{% endstylesheet %}

{% schema %}
{
  "name": "Process steps",
  "tag": "section",
  "class": "section-onterior-process",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Crafted to Perfection" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Thoughtful Process. Exceptional Results." },
    { "type": "richtext", "id": "body", "label": "Body text", "default": "<p>Every Onterior piece goes through a meticulous process to ensure it meets our highest standards of quality and design.</p>" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "Finest Materials" },
        { "type": "text", "id": "text", "label": "Text", "default": "We source the best leather and metals from trusted suppliers." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [{
    "name": "Process steps",
    "blocks": [
      { "type": "step", "settings": { "number": "01", "title": "Finest Materials", "text": "We source the best leather and metals from trusted suppliers." } },
      { "type": "step", "settings": { "number": "02", "title": "Skilled Craftsmanship", "text": "Our artisans handcraft every detail with precision and care." } },
      { "type": "step", "settings": { "number": "03", "title": "Quality Check", "text": "Every piece is inspected to ensure perfection." } },
      { "type": "step", "settings": { "number": "04", "title": "Perfectly Packed", "text": "Carefully packaged to reach you in perfect condition." } }
    ]
  }]
}
{% endschema %}
