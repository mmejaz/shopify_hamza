{{ 'onterior-base.css' | asset_url | stylesheet_tag }}

<section class="ont onterior-info-page ont-info--{{ section.settings.layout_style | default: 'standard' }}" style="background: var(--ont-cream);">
  <div class="ont-container">
    <header class="ont-info__head">
      {%- if section.settings.eyebrow != blank -%}<p class="ont-eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h1 class="ont-serif ont-info__title">{{ section.settings.heading }}</h1>{%- endif -%}
      {%- if section.settings.intro != blank -%}<div class="ont-info__intro rte">{{ section.settings.intro }}</div>{%- endif -%}
      {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
        <a href="{{ section.settings.cta_link }}" class="ont-info__cta">{{ section.settings.cta_label }}</a>
      {%- endif -%}
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="ont-info__content">
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq' -%}
            <details class="ont-info__faq" {{ block.shopify_attributes }}>
              <summary>
                <span>{{ block.settings.question }}</span>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
              </summary>
              {%- if block.settings.answer != blank -%}<div class="ont-info__answer rte">{{ block.settings.answer }}</div>{%- endif -%}
            </details>
          {%- else -%}
            <article class="ont-info__block" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}<h2 class="ont-serif ont-info__block-title">{{ block.settings.heading }}</h2>{%- endif -%}
              {%- if block.settings.body != blank -%}<div class="ont-info__body rte">{{ block.settings.body }}</div>{%- endif -%}
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .onterior-info-page { position: relative; overflow: hidden; padding-top: 56px; padding-bottom: 72px; }
  .onterior-info-page::before { content: ''; position: absolute; inset: 0 0 auto; height: 260px; background: linear-gradient(180deg, rgba(22,19,17,.08), rgba(22,19,17,0)); pointer-events: none; }
  @media (min-width: 1024px) { .onterior-info-page { padding-top: 88px; padding-bottom: 104px; } }
  .ont-info__head { position: relative; max-width: 820px; margin: 0 auto 44px; text-align: center; }
  .ont-info__title { margin: 0; color: var(--ont-ink); font-size: 36px; line-height: 1.15; font-weight: 600; }
  @media (min-width: 750px) { .ont-info__title { font-size: 48px; } }
  .ont-info__intro { margin-top: 22px; color: var(--ont-stone); font-size: 15px; line-height: 1.9; }
  .ont-info__intro p { margin: 0 0 1em; }
  .ont-info__cta { display: inline-flex; align-items: center; justify-content: center; margin-top: 18px; min-height: 44px; padding: 0 22px; border: 1px solid rgba(22,19,17,.18); background: var(--ont-ink); color: var(--ont-cream); text-decoration: none; font-size: 11px; font-weight: 600; letter-spacing: .14em; text-transform: uppercase; transition: transform .3s ease, background-color .3s ease; }
  .ont-info__cta:hover { background: var(--ont-bronze); color: var(--ont-ink); transform: translateY(-2px); }
  .ont-info__content { position: relative; max-width: 860px; margin-inline: auto; display: grid; gap: 28px; }
  .ont-info__block { padding-top: 28px; border-top: 1px solid rgba(22,19,17,.12); }
  .ont-info__block:first-child { padding-top: 0; border-top: 0; }
  .ont-info__block-title { margin: 0 0 16px; color: var(--ont-ink); font-size: 24px; line-height: 1.25; font-weight: 600; }
  .ont-info__body { color: var(--ont-stone); font-size: 15px; line-height: 1.9; }
  .ont-info__body p { margin: 0 0 1em; }
  .ont-info__body ul { margin: 0 0 1em 1.2em; padding: 0; }
  .ont-info__body li { margin-bottom: 8px; }
  .ont-info--faq .ont-info__content { max-width: 980px; gap: 16px; }
  .ont-info--faq .ont-info__block { padding: 28px; border: 1px solid rgba(22,19,17,.1); background: rgba(255,255,255,.48); box-shadow: 0 24px 70px -54px rgba(22,19,17,.5); }
  .ont-info--faq .ont-info__body ul { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 0; list-style: none; }
  @media (min-width: 700px) { .ont-info--faq .ont-info__body ul { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  .ont-info--faq .ont-info__body li { position: relative; margin: 0; padding: 14px 16px 14px 42px; border: 1px solid rgba(201,160,94,.34); background: var(--ont-cream); color: var(--ont-ink); font-size: 14px; line-height: 1.5; }
  .ont-info--faq .ont-info__body li::before { content: '?'; position: absolute; left: 14px; top: 14px; display: grid; place-items: center; width: 18px; height: 18px; border-radius: 999px; background: var(--ont-bronze); color: var(--ont-ink); font-size: 11px; font-weight: 700; }
  .ont-info__faq { border: 1px solid rgba(22,19,17,.12); background: rgba(255,255,255,.62); transition: border-color .25s ease, box-shadow .25s ease, transform .25s ease; }
  .ont-info__faq[open], .ont-info__faq:hover { border-color: rgba(201,160,94,.52); box-shadow: 0 24px 70px -56px rgba(22,19,17,.7); transform: translateY(-1px); }
  .ont-info__faq summary { display: flex; align-items: center; justify-content: space-between; gap: 20px; padding: 20px 22px; color: var(--ont-ink); cursor: pointer; font-size: 16px; font-weight: 600; list-style: none; }
  .ont-info__faq summary::-webkit-details-marker { display: none; }
  .ont-info__faq svg { flex: 0 0 auto; width: 20px; height: 20px; color: var(--ont-bronze); transition: transform .25s ease; }
  .ont-info__faq[open] svg { transform: rotate(45deg); }
  .ont-info__answer { padding: 0 22px 22px; color: var(--ont-stone); font-size: 14px; line-height: 1.85; }
  .ont-info__answer p { margin: 0 0 1em; }
  .ont-info--shipping .ont-info__content { max-width: 1040px; grid-template-columns: 1fr; gap: 18px; counter-reset: ship-step; }
  @media (min-width: 780px) { .ont-info--shipping .ont-info__content { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  .ont-info--shipping .ont-info__block { position: relative; min-height: 220px; padding: 34px 30px 30px; border: 1px solid rgba(22,19,17,.1); background: linear-gradient(145deg, rgba(255,255,255,.72), rgba(255,255,255,.34)); box-shadow: 0 26px 78px -60px rgba(22,19,17,.8); overflow: hidden; counter-increment: ship-step; transition: border-color .3s ease, transform .3s ease, box-shadow .3s ease; }
  .ont-info--shipping .ont-info__block::before { content: '0' counter(ship-step); position: absolute; right: 24px; top: 18px; color: rgba(201,160,94,.28); font-family: var(--ont-serif); font-size: 58px; line-height: 1; }
  .ont-info--shipping .ont-info__block::after { content: ''; position: absolute; left: 30px; bottom: 0; width: 70px; height: 3px; background: var(--ont-bronze); }
  .ont-info--shipping .ont-info__block:hover { border-color: rgba(201,160,94,.42); transform: translateY(-3px); box-shadow: 0 32px 90px -62px rgba(22,19,17,.9); }
  .ont-info--shipping .ont-info__block-title { position: relative; max-width: 72%; margin-bottom: 20px; font-size: 25px; }
  .ont-info--shipping .ont-info__body { position: relative; max-width: 92%; font-size: 14px; line-height: 1.85; }
  .ont-info--shipping .ont-info__body ul { margin: 0; list-style: none; display: grid; gap: 10px; }
  .ont-info--shipping .ont-info__body li { position: relative; margin: 0; padding-left: 28px; }
  .ont-info--shipping .ont-info__body li::before { content: ''; position: absolute; left: 0; top: .72em; width: 14px; height: 1px; background: var(--ont-bronze); }
  .ont-info--shipping .ont-info__cta { background: transparent; color: var(--ont-ink); border-color: rgba(201,160,94,.55); }
  .ont-info--shipping .ont-info__cta:hover { background: var(--ont-ink); color: var(--ont-cream); }
  .ont-info--returns .ont-info__content { max-width: 920px; }
  .ont-info--returns .ont-info__block { position: relative; padding: 36px 30px; border: 1px solid rgba(22,19,17,.1); background: linear-gradient(135deg, rgba(255,255,255,.76), rgba(255,255,255,.36)); box-shadow: 0 28px 84px -62px rgba(22,19,17,.82); overflow: hidden; }
  .ont-info--returns .ont-info__block::before { content: ''; position: absolute; right: -80px; top: -120px; width: 240px; height: 240px; border-radius: 999px; border: 1px solid rgba(201,160,94,.28); }
  .ont-info--returns .ont-info__block::after { content: '✓'; position: absolute; right: 30px; top: 28px; display: grid; place-items: center; width: 44px; height: 44px; border-radius: 999px; background: var(--ont-bronze); color: var(--ont-ink); font-size: 22px; font-weight: 700; }
  .ont-info--returns .ont-info__block-title { position: relative; max-width: 72%; margin-bottom: 22px; font-size: 28px; }
  .ont-info--returns .ont-info__body { position: relative; font-size: 15px; line-height: 1.9; }
  .ont-info--returns .ont-info__body ul { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 0 0 22px; list-style: none; }
  @media (min-width: 720px) { .ont-info--returns .ont-info__body ul { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  .ont-info--returns .ont-info__body li { position: relative; margin: 0; padding: 18px 16px 18px 46px; border: 1px solid rgba(201,160,94,.36); background: rgba(247,243,236,.82); color: var(--ont-ink); font-size: 14px; line-height: 1.55; }
  .ont-info--returns .ont-info__body li::before { content: ''; position: absolute; left: 17px; top: 22px; width: 13px; height: 7px; border-left: 2px solid var(--ont-bronze); border-bottom: 2px solid var(--ont-bronze); transform: rotate(-45deg); }
  .ont-info--returns .ont-info__body p { padding-left: 18px; border-left: 2px solid rgba(201,160,94,.55); }
  .ont-info--returns .ont-info__cta { background: var(--ont-ink); color: var(--ont-cream); }
  .ont-info--care .ont-info__content { max-width: 980px; }
  .ont-info--care .ont-info__block { position: relative; padding: 34px 30px; border: 1px solid rgba(22,19,17,.1); background: linear-gradient(135deg, rgba(255,255,255,.76), rgba(255,255,255,.38)); box-shadow: 0 28px 82px -62px rgba(22,19,17,.78); overflow: hidden; }
  .ont-info--care .ont-info__block::before { content: ''; position: absolute; inset: 18px; border: 1px solid rgba(201,160,94,.16); pointer-events: none; }
  .ont-info--care .ont-info__block-title { position: relative; margin-bottom: 24px; font-size: 28px; }
  .ont-info--care .ont-info__body { position: relative; font-size: 15px; line-height: 1.9; }
  .ont-info--care .ont-info__body ul { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 0 0 24px; list-style: none; }
  @media (min-width: 720px) { .ont-info--care .ont-info__body ul { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  .ont-info--care .ont-info__body li { position: relative; margin: 0; min-height: 82px; padding: 18px 18px 18px 58px; border: 1px solid rgba(201,160,94,.34); background: rgba(247,243,236,.86); color: var(--ont-ink); font-size: 14px; line-height: 1.55; }
  .ont-info--care .ont-info__body li::before { content: ''; position: absolute; left: 18px; top: 20px; width: 24px; height: 24px; border-radius: 999px; border: 1px solid rgba(201,160,94,.7); background: radial-gradient(circle at center, var(--ont-bronze) 0 3px, transparent 4px); }
  .ont-info--care .ont-info__body p { margin-top: 18px; padding: 18px 20px; border-left: 3px solid var(--ont-bronze); background: rgba(22,19,17,.04); color: var(--ont-ink); }
  .ont-info--care .ont-info__cta { background: transparent; color: var(--ont-ink); border-color: rgba(201,160,94,.55); }
  .ont-info--care .ont-info__cta:hover { background: var(--ont-ink); color: var(--ont-cream); }
  .ont-info--privacy .ont-info__content { max-width: 1040px; grid-template-columns: 1fr; gap: 20px; }
  @media (min-width: 820px) { .ont-info--privacy .ont-info__content { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  .ont-info--privacy .ont-info__block { position: relative; min-height: 280px; padding: 34px 30px 30px; border: 1px solid rgba(22,19,17,.1); background: linear-gradient(140deg, rgba(255,255,255,.78), rgba(255,255,255,.36)); box-shadow: 0 28px 84px -62px rgba(22,19,17,.8); overflow: hidden; }
  .ont-info--privacy .ont-info__block::before { content: ''; position: absolute; right: 26px; top: 28px; width: 42px; height: 50px; border: 1px solid rgba(201,160,94,.7); border-radius: 18px 18px 6px 6px; }
  .ont-info--privacy .ont-info__block::after { content: ''; position: absolute; right: 37px; top: 18px; width: 20px; height: 18px; border: 1px solid rgba(201,160,94,.7); border-bottom: 0; border-radius: 18px 18px 0 0; }
  .ont-info--privacy .ont-info__block-title { position: relative; max-width: 72%; margin-bottom: 22px; font-size: 27px; }
  .ont-info--privacy .ont-info__body { position: relative; font-size: 15px; line-height: 1.9; }
  .ont-info--privacy .ont-info__body ul { display: grid; gap: 12px; margin: 0 0 24px; list-style: none; }
  .ont-info--privacy .ont-info__body li { position: relative; margin: 0; padding: 14px 16px 14px 46px; border: 1px solid rgba(201,160,94,.34); background: rgba(247,243,236,.86); color: var(--ont-ink); font-size: 14px; line-height: 1.55; }
  .ont-info--privacy .ont-info__body li::before { content: ''; position: absolute; left: 16px; top: 18px; width: 16px; height: 16px; border: 1px solid var(--ont-bronze); border-radius: 999px; box-shadow: inset 0 0 0 4px rgba(201,160,94,.16); }
  .ont-info--privacy .ont-info__body p { margin-top: 18px; padding: 18px 20px; border-left: 3px solid var(--ont-bronze); background: rgba(22,19,17,.04); color: var(--ont-ink); }
  .ont-info--privacy .ont-info__cta { background: var(--ont-ink); color: var(--ont-cream); }
  .ont-info--terms .ont-info__content { max-width: 1020px; }
  .ont-info--terms .ont-info__block { position: relative; padding: 36px 30px 32px; border: 1px solid rgba(22,19,17,.1); background: linear-gradient(135deg, rgba(255,255,255,.78), rgba(255,255,255,.34)); box-shadow: 0 28px 84px -62px rgba(22,19,17,.82); overflow: hidden; }
  .ont-info--terms .ont-info__block::before { content: '§'; position: absolute; right: 28px; top: 18px; color: rgba(201,160,94,.22); font-family: var(--ont-serif); font-size: 76px; line-height: 1; }
  .ont-info--terms .ont-info__block::after { content: ''; position: absolute; left: 30px; right: 30px; bottom: 0; height: 3px; background: linear-gradient(90deg, var(--ont-bronze), rgba(201,160,94,.12)); }
  .ont-info--terms .ont-info__block-title { position: relative; max-width: 76%; margin-bottom: 24px; font-size: 28px; }
  .ont-info--terms .ont-info__body { position: relative; font-size: 15px; line-height: 1.9; }
  .ont-info--terms .ont-info__body ul { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 0 0 24px; list-style: none; counter-reset: term-item; }
  @media (min-width: 760px) { .ont-info--terms .ont-info__body ul { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  .ont-info--terms .ont-info__body li { position: relative; margin: 0; min-height: 72px; padding: 18px 16px 18px 48px; border: 1px solid rgba(201,160,94,.34); background: rgba(247,243,236,.86); color: var(--ont-ink); font-size: 14px; line-height: 1.5; counter-increment: term-item; }
  .ont-info--terms .ont-info__body li::before { content: counter(term-item); position: absolute; left: 16px; top: 18px; display: grid; place-items: center; width: 20px; height: 20px; border-radius: 999px; background: var(--ont-bronze); color: var(--ont-ink); font-size: 11px; font-weight: 700; }
  .ont-info--terms .ont-info__body p { margin-top: 20px; padding: 18px 20px; border-left: 3px solid var(--ont-bronze); background: rgba(22,19,17,.04); color: var(--ont-ink); }
  .ont-info--terms .ont-info__cta { background: transparent; color: var(--ont-ink); border-color: rgba(201,160,94,.55); }
  .ont-info--terms .ont-info__cta:hover { background: var(--ont-ink); color: var(--ont-cream); }
{% endstylesheet %}

{% schema %}
{
  "name": "Onterior info page",
  "tag": "section",
  "class": "section-onterior-info-page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Customer Care" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "richtext", "id": "intro", "label": "Intro text" },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout style",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "faq", "label": "FAQ" },
        { "value": "shipping", "label": "Shipping" },
        { "value": "returns", "label": "Returns" },
        { "value": "care", "label": "Care" },
        { "value": "privacy", "label": "Privacy" },
        { "value": "terms", "label": "Terms" }
      ],
      "default": "standard"
    },
    { "type": "text", "id": "cta_label", "label": "Button label" },
    { "type": "url", "id": "cta_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "content",
      "name": "Content block",
      "settings": [
        { "type": "inline_richtext", "id": "heading", "label": "Heading" },
        { "type": "richtext", "id": "body", "label": "Body" }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ row",
      "settings": [
        { "type": "inline_richtext", "id": "question", "label": "Question", "default": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Onterior info page",
      "blocks": [
        { "type": "content" }
      ]
    }
  ]
}
{% endschema %}
