{%- comment -%}
  Onterior — Home collections grid. Heading + "view all" link + collection cards.
  Each card is a block pointing at a real Shopify collection (image + title auto).
{%- endcomment -%}

{{ 'onterior-base.css' | asset_url | stylesheet_tag }}

<section class="ont onterior-collections" style="background: var(--ont-cream);">
  <div class="ont-container">
    <div class="ont-col__head ont-reveal">
      <div>
        {%- if section.settings.eyebrow != blank -%}<p class="ont-eyebrow" style="color: var(--ont-bronze);">{{ section.settings.eyebrow }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="ont-serif ont-col__title">{{ section.settings.heading }}</h2>{%- endif -%}
      </div>
      {%- if section.settings.link_label != blank -%}
        <a class="ont-col__viewall" href="{{ section.settings.link_url | default: '#' }}">
          {{ section.settings.link_label }}
          <svg width="26" height="10" viewBox="0 0 30 10" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><path d="M0 5h27M23 1l4 4-4 4"/></svg>
        </a>
      {%- endif -%}
    </div>

    <div class="ont-col__grid ont-reveal">
      {%- for block in section.blocks -%}
        {%- assign col = block.settings.collection -%}
        {%- assign card_img = block.settings.image | default: col.featured_image -%}
        {%- assign card_title = block.settings.title | default: col.title -%}
        <a class="ont-col__card" {% if col != blank %}href="{{ col.url }}"{% else %}href="{{ block.settings.link | default: '#' }}"{% endif %} {{ block.shopify_attributes }}>
          <div class="ont-col__imgwrap">
            {%- if card_img != blank -%}
              {{ card_img | image_url: width: 600 | image_tag: loading: 'lazy', sizes: '(min-width: 1024px) 220px, 45vw', widths: '250, 400, 600', alt: card_title, class: 'ont-col__img' }}
            {%- elsif block.settings.image_asset != blank -%}
              <img class="ont-col__img" src="{{ block.settings.image_asset | asset_url }}" alt="{{ card_title | escape }}" loading="lazy" width="600" height="600">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'ont-col__img ont-ph' }}
            {%- endif -%}
          </div>
          <div class="ont-col__footer">
            {%- if card_title != blank -%}<p class="ont-col__name">{{ card_title }}</p>{%- endif -%}
            <div class="ont-col__meta">
              {%- if block.settings.description != blank -%}<p class="ont-col__desc">{{ block.settings.description }}</p>{%- endif -%}
              <span class="ont-col__arrow" aria-hidden="true">{%- render 'onterior-icon', name: 'arrow' -%}</span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<script src="{{ 'onterior.js' | asset_url }}" defer="defer"></script>

{% stylesheet %}
  .onterior-collections { padding-bottom: 64px; }
  @media (min-width: 1024px) { .onterior-collections { padding-bottom: 96px; } }
  .ont-col__head { display: flex; flex-direction: column; gap: 24px; margin-bottom: 40px; }
  @media (min-width: 640px) { .ont-col__head { flex-direction: row; align-items: flex-end; justify-content: space-between; } }
  .ont-col__title { color: var(--ont-ink); font-weight: 500; font-size: 30px; margin: 0; }
  @media (min-width: 1024px) { .ont-col__title { font-size: 38px; } }
  .ont-col__viewall { display: inline-flex; align-items: center; gap: 16px; color: var(--ont-ink); font-size: 11px; letter-spacing: .16em; text-transform: uppercase; font-weight: 500; text-decoration: none; border-bottom: 1px solid rgba(185,138,68,.6); padding-bottom: 8px; flex-shrink: 0; }
  .ont-col__viewall svg { transition: transform .3s ease; }
  .ont-col__viewall:hover svg { transform: translateX(5px); }
  .ont-col__grid { display: grid; grid-template-columns: 1fr; gap: 16px; }
  @media (min-width: 640px) { .ont-col__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 768px) { .ont-col__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .ont-col__grid { grid-template-columns: repeat(5, 1fr); } }
  .ont-col__card { text-decoration: none; display: flex; flex-direction: column; background: var(--ont-ink); }
  .ont-col__imgwrap { overflow: hidden; aspect-ratio: 1 / 1; }
  .ont-col__img { width: 100%; height: 100%; object-fit: cover; transition: transform .7s ease; }
  .ont-col__card:hover .ont-col__img { transform: scale(1.06); }
  .ont-col__footer { flex: 1; display: flex; flex-direction: column; background: var(--ont-ink); color: var(--ont-cream); padding: 22px 20px 24px; }
  .ont-col__name { margin: 0 0 14px; font-size: 13px; letter-spacing: .16em; text-transform: uppercase; color: var(--ont-cream); font-weight: 600; line-height: 1.35; }
  .ont-col__meta { margin-top: auto; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .ont-col__desc { margin: 0; font-size: 13px; line-height: 1.5; font-weight: 300; color: rgba(247,243,236,.6); }
  .ont-col__arrow { flex-shrink: 0; color: var(--ont-sand); display: grid; place-items: center; transition: transform .3s ease; }
  .ont-col__arrow svg { width: 22px; height: 22px; }
  .ont-col__card:hover .ont-col__arrow { transform: translateX(4px); }
  .ont-ph { background: var(--ont-linen); }
{% endstylesheet %}

{% schema %}
{
  "name": "Home collections",
  "tag": "section",
  "class": "section-onterior-collections",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Collections" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Timeless Pieces for Every Space" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View All Collections" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Custom image (upload)" },
        { "type": "text", "id": "image_asset", "label": "Asset image filename", "info": "Fallback: a file in assets/, e.g. onterior-product-1.png." },
        { "type": "text", "id": "title", "label": "Custom title (optional)" },
        { "type": "text", "id": "description", "label": "Description" },
        { "type": "url", "id": "link", "label": "Custom link (if no collection)" }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [{
    "name": "Home collections",
    "blocks": [
      { "type": "collection_card", "settings": { "title": "Decor Trays" } },
      { "type": "collection_card", "settings": { "title": "Leather Accessories" } },
      { "type": "collection_card", "settings": { "title": "Desk & Office" } },
      { "type": "collection_card", "settings": { "title": "Tissue Box Covers" } },
      { "type": "collection_card", "settings": { "title": "Coasters" } }
    ]
  }]
}
{% endschema %}
